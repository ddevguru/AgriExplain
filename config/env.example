# Copy to .env and fill values
APP_NAME=AgriXplain
APP_ENV=dev
APP_HOST=0.0.0.0
APP_PORT=8000

# MySQL DSN: mysql+mysqldb://user:password@host:3306/dbname
DATABASE_URL=mysql+mysqldb://root:password@127.0.0.1:3306/agrixplain

# JWT
JWT_SECRET=change_me_super_secret
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=60

# Weather API (placeholder)
WEATHER_API_KEY=
WEATHER_API_BASE=https://api.open-meteo.com/v1/forecast
